---
import { useTranslations, type Language } from "../i18n/index";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const categories = [
  { key: "backend", items: t.stack.backend },
  { key: "frontend", items: t.stack.frontend },
  { key: "databases", items: t.stack.databases },
  { key: "ai", items: t.stack.ai },
  { key: "architecture", items: t.stack.architecture },
  { key: "infrastructure", items: t.stack.infrastructure },
];

const techLogos: Record<string, { abbr: string; color: string }> = {
  NestJS: { abbr: "N", color: "#E0234E" },
  Laravel: { abbr: "L", color: "#FF2D20" },
  TypeScript: { abbr: "TS", color: "#3178C6" },
  React: { abbr: "R", color: "#61DAFB" },
  "Vue.js": { abbr: "V", color: "#4FC08D" },
  Astro: { abbr: "A", color: "#FF5D01" },
  TailwindCSS: { abbr: "TW", color: "#06B6D4" },
  Redux: { abbr: "Redux", color: "#764ABC" },
  "Framer Motion": { abbr: "FM", color: "#0055FF" },
  MySQL: { abbr: "SQL", color: "#4479A1" },
  "SQL Server": { abbr: "SQL", color: "#CC2927" },
  MongoDB: { abbr: "M", color: "#47A248" },
  Redis: { abbr: "R", color: "#DC382D" },
  LLMs: { abbr: "LLM", color: "#9333EA" },
  "AI Agents": { abbr: "AI", color: "#9333EA" },
  "Agentic Skills": { abbr: "SKL", color: "#9333EA" },
  MCPs: { abbr: "MCP", color: "#9333EA" },
  LangChain: { abbr: "LC", color: "#9333EA" },
  Docker: { abbr: "D", color: "#2496ED" },
  Kubernetes: { abbr: "K8", color: "#326CE5" },
};
---

<section id="stack" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <h2
      class="text-3xl md:text-4xl font-bold text-center mb-16 animate-on-scroll"
    >
      {t.stack.title}
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4">
      {
        categories.map((category, catIndex) => (
          <div
            class="animate-on-scroll"
            style={`animation-delay: ${catIndex * 0.1}s;`}
          >
            <h3 class="text-xs font-semibold text-accent-purple uppercase tracking-wider mb-3">
              {
                t.stack.categories[
                  category.key as keyof typeof t.stack.categories
                ]
              }
            </h3>
            <div class="space-y-1.5">
              {category.items.map((item) => {
                const logo = techLogos[item];
                return (
                  <div class="group flex items-center gap-2 px-2.5 py-1.5 rounded-md dark:bg-[#131318] bg-white border dark:border-border/50 border-zinc-200 dark:hover:border-accent-purple/50 hover:border-accent-purple/50 dark:hover:bg-[#1a1a20] bg-zinc-50 transition-all duration-200 cursor-default">
                    {logo && (
                      <div
                        class="w-6 h-6 rounded flex items-center justify-center text-[9px] font-bold flex-shrink-0"
                        style={`background: ${logo.color}22; color: ${logo.color};`}
                      >
                        {logo.abbr}
                      </div>
                    )}
                    <span class="text-xs text-text-secondary group-hover:text-text-primary transition-colors duration-200 truncate">
                      {item}
                    </span>
                  </div>
                );
              })}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
